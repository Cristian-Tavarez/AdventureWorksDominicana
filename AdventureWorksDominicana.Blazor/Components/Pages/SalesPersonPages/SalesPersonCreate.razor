@page "/sales-people/create"
@using AdventureWorksDominicana.Data.Models
@using AdventureWorksDominicana.Services
@inject SalesPersonService SalesPersonService
@inject NavigationManager NavigationManager
@rendermode InteractiveServer

<div class="container mt-4">
    <div class="card shadow-lg">
        <div class="card-header bg-white"><h5 class="mb-0 fw-bold">Crear Registro de Vendedor</h5></div>
        <div class="card-body p-4">
            <EditForm Model="@vendedor" OnSubmit="IntentarGuardar">
                
                
                <div class="mb-3">
                    <label><strong>ID de Empleado (BusinessEntityId)</strong></label>
                    <InputNumber @bind-Value="vendedor.BusinessEntityId" class="form-control" />
                    @if (errores.Contains("ID"))
                    {
                        <span class="text-danger small">El ID es obligatorio y debe ser mayor a 0.</span>
                    }
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label><strong>ID de Territorio</strong></label>
                        <InputNumber @bind-Value="vendedor.TerritoryId" class="form-control" />
                        @if (errores.Contains("Territorio"))
                        {
                            <span class="text-danger small">El Territorio es obligatorio.</span>
                        }
                    </div>
                    <div class="col-md-6 mb-3">
                        <label><strong>Ventas Actuales (YTD)</strong></label>
                        <InputNumber @bind-Value="vendedor.SalesYtd" class="form-control" />
                    </div>
                </div>

                @if (errores.Any())
                {
                    <div class="alert alert-danger py-2 mt-2 small"><i class="bi bi-x-circle"></i> Hay campos vacíos o incorrectos.</div>
                }

                <div class="card-footer text-center bg-white border-top pt-3">
                    <button type="button" class="btn btn-secondary" @onclick="Volver"><i class="bi bi-arrow-left"></i> Volver</button>
                    <button type="submit" class="btn btn-primary"><i class="bi bi-floppy"></i> Guardar</button>
                </div>
            </EditForm>
        </div>
    </div>
</div>

@code {
    private SalesPerson vendedor = new SalesPerson();
    private List<string> errores = new List<string>();

    private async Task IntentarGuardar()
    {
        errores.Clear();

        
        if (vendedor.BusinessEntityId <= 0) errores.Add("ID");
        if (vendedor.TerritoryId == null || vendedor.TerritoryId <= 0) errores.Add("Territorio");

        if (errores.Any()) return; 

        if (await SalesPersonService.CreateAsync(vendedor)) Volver();
    }
    private void Volver() => NavigationManager.NavigateTo("/sales-people");
}