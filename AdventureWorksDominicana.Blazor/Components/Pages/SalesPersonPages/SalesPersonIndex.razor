@page "/sales-people"
@using AdventureWorksDominicana.Data.Models
@using AdventureWorksDominicana.Services
@using Microsoft.AspNetCore.Components.QuickGrid
@inject SalesPersonService SalesPersonService
@inject NavigationManager NavigationManager
@rendermode InteractiveServer

<PageTitle>Registro de Vendedores</PageTitle>

<div class="container-fluid p-0">
    
    <div class="d-flex justify-content-between align-items-center p-3 bg-light border-bottom shadow-sm">
        <h5 class="mb-0 text-dark fw-bold">Registro de Vendedores</h5>
        <button class="btn btn-primary btn-sm px-4 shadow-sm" @onclick="IrACrear">
            <i class="bi bi-person-plus-fill"></i> Crear
        </button>
    </div>

    <div class="p-4 bg-white">
       
        <div class="row g-3 mb-4 align-items-end border rounded p-3 bg-light/50">
            <div class="col-12 col-md-4">
                <label class="form-label small fw-bold">Buscar por ID o Territorio</label>
                <input type="text" class="form-control form-control-sm"
                       placeholder="Ej: 274 o North..."
                       @bind="textoBusqueda" />
            </div>
            <div class="col-12 col-md-8 d-flex gap-2">
                <button class="btn btn-outline-primary btn-sm px-3" @onclick="AplicarFiltro">
                    <i class="bi bi-search"></i> Buscar
                </button>
                <button class="btn btn-outline-primary btn-sm px-3" @onclick="LimpiarBusqueda">
                    <i class="bi bi-arrow-clockwise"></i> Limpiar
                </button>
            </div>
        </div>

        @if (vendedores == null)
        {
            <div class="text-center py-5">
                <div class="spinner-border text-primary" role="status"></div>
                <p class="mt-2 text-muted">Cargando datos...</p>
            </div>
        }
        else
        {
            <div class="table-responsive border rounded shadow-sm">
                <QuickGrid Items="@FilteredSalesPeople" Pagination="@paginacion" Class="table table-bordered table-hover table-sm mb-0 custom-table">
                    
                    <PropertyColumn Property="@(p => p.BusinessEntityId)" Title="ID" Sortable="true" />
                    
                    <TemplateColumn Title="Nombre del Vendedor" Sortable="true">
                        <ChildContent>
                            @{
                                var persona = context.BusinessEntity?.BusinessEntity;
                                <span class="fw-normal text-dark">@(persona != null ? $"{persona.FirstName} {persona.LastName}" : $"ID: {context.BusinessEntityId}")</span>
                            }
                        </ChildContent>
                    </TemplateColumn>
                    
                    <TemplateColumn Title="Territorio" Sortable="true">
                        @if (context.Territory != null)
                        {
                            <span class="badge bg-primary px-2">@context.Territory.Name</span>
                        }
                        else
                        {
                            <span class="text-muted small">N/A</span>
                        }
                    </TemplateColumn>

                   
                    <PropertyColumn Property="@(p => p.SalesQuota)" Title="Cuota" Format="C2" Sortable="true" />
                    <PropertyColumn Property="@(p => p.SalesYtd)" Title="Ventas YTD" Format="C2" Sortable="true" />
                    <PropertyColumn Property="@(p => p.CommissionPct)" Title="Comisión" Format="P2" Sortable="true" />

                    <TemplateColumn Title="Opciones" Class="text-center">
                        <div class="d-flex justify-content-center gap-1">
                            <button class="btn btn-primary btn-xs d-flex align-items-center gap-1"
                                    @onclick="() => IrAEditar(context.BusinessEntityId)">
                                <i class="bi bi-pencil-square"></i> <span class="d-none d-lg-inline">Editar</span>
                            </button>
                        </div>
                    </TemplateColumn>
                </QuickGrid>
            </div>

            <div class="mt-3 custom-pagination">
                <Paginator State="@paginacion" />
            </div>
        }
    </div>
</div>

<style>
    .btn-xs {
        padding: 0.25rem 0.5rem;
        font-size: 0.75rem;
    }

    .custom-table td {
        background-color: white !important;
        color: #212529 !important;
        vertical-align: middle;
    }

    ::deep .custom-pagination .quickgrid-paginator {
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-direction: row;
    }

    ::deep .custom-pagination .pagination-text {
        order: -1;
        margin-right: auto;
        font-weight: 600;
    }
</style>

@code {
    private List<SalesPerson>? vendedores;
    private string textoBusqueda = "";
    private IQueryable<SalesPerson>? filteredList;
    PaginationState paginacion = new PaginationState { ItemsPerPage = 5 };

    protected override async Task OnInitializedAsync()
    {
        vendedores = await SalesPersonService.GetSalesPeopleAsync();
        AplicarFiltro();
    }

    private IQueryable<SalesPerson> FilteredSalesPeople => filteredList ?? Enumerable.Empty<SalesPerson>().AsQueryable();

    private void AplicarFiltro()
    {
        if (vendedores == null) return;
        var query = vendedores.AsQueryable();

        if (!string.IsNullOrWhiteSpace(textoBusqueda))
        {
            query = query.Where(s =>
                s.BusinessEntityId.ToString().Contains(textoBusqueda) ||
                (s.Territory != null && s.Territory.Name.Contains(textoBusqueda, StringComparison.OrdinalIgnoreCase))
            );
        }
        filteredList = query;
    }

    private void LimpiarBusqueda()
    {
        textoBusqueda = "";
        AplicarFiltro();
    }

    private void IrACrear() => NavigationManager.NavigateTo("/sales-people/create");
    private void IrAEditar(int id) => NavigationManager.NavigateTo($"/sales-people/edit/{id}");
}