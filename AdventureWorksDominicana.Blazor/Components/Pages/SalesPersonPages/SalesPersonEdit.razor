@page "/sales-people/edit/{id:int}"
@using AdventureWorksDominicana.Data.Models
@using AdventureWorksDominicana.Services
@inject SalesPersonService SalesPersonService
@inject NavigationManager NavigationManager
@rendermode InteractiveServer

<PageTitle>Editar Registro de Vendedor</PageTitle>

<div class="container mt-4">
    <div class="card shadow-sm">
        <div class="card-header bg-light">
            <h5 class="mb-0 fw-bold">Editar Registro de Vendedor</h5>
        </div>
        <div class="card-body p-4">
            @if (vendedor == null)
            {
                <div class="text-center py-5">
                    <div class="spinner-border text-primary" role="status"></div>
                    <p class="mt-2 text-muted">Cargando datos desde Somee...</p>
                </div>
            }
            else
            {
                <EditForm Model="@vendedor" OnValidSubmit="ActualizarVendedor">
                    <DataAnnotationsValidator />

                    <div class="row g-3 mb-3">
                        <div class="col-12 col-md-6">
                            <label class="form-label fw-bold small">ID de Entidad de Negocio</label>
                            <input type="number" class="form-control bg-light" value="@vendedor.BusinessEntityId" readonly />
                        </div>
                        <div class="col-12 col-md-6">
                            <label class="form-label fw-bold small">ID de Territorio</label>
                            <InputNumber @bind-Value="vendedor.TerritoryId" class="form-control" />
                        </div>
                    </div>

                    <div class="row g-3 mb-3">
                        <div class="col-12 col-md-6">
                            <label class="form-label fw-bold small">Cuota de Ventas Proyectada</label>
                            <div class="input-group">
                                <span class="input-group-text">$</span>
                                <InputNumber @bind-Value="vendedor.SalesQuota" class="form-control" />
                            </div>
                        </div>
                        <div class="col-12 col-md-6">
                            <label class="form-label fw-bold small">Bono por Meta</label>
                            <div class="input-group">
                                <span class="input-group-text">$</span>
                                <InputNumber @bind-Value="vendedor.Bonus" class="form-control" />
                            </div>
                        </div>
                    </div>

                    <div class="row g-3 mb-4">
                        <div class="col-12 col-md-6">
                            <label class="form-label fw-bold small">Porcentaje de Comisión</label>
                            <div class="input-group">
                                <InputNumber @bind-Value="vendedor.CommissionPct" class="form-control" />
                                <span class="input-group-text">%</span>
                            </div>
                        </div>
                        <div class="col-12 col-md-6">
                            
                            <label class="form-label fw-bold small">Ventas Actuales (YTD)</label>
                            <div class="input-group">
                                <span class="input-group-text">$</span>
                                <InputNumber @bind-Value="vendedor.SalesYtd" class="form-control" />
                            </div>
                        </div>
                    </div>

                    <div class="d-flex justify-content-center gap-2 border-top pt-4">
                        <button type="button" class="btn btn-secondary px-4 shadow-sm d-flex align-items-center gap-2" @onclick="Volver">
                            <i class="bi bi-arrow-left"></i> Volver
                        </button>
                        <button type="submit" class="btn btn-primary px-4 shadow-sm d-flex align-items-center gap-2">
                            <i class="bi bi-floppy-fill"></i> Guardar
                        </button>
                        <button type="button" class="btn btn-danger px-4 shadow-sm d-flex align-items-center gap-2" @onclick="Eliminar">
                            <i class="bi bi-trash3-fill"></i> Eliminar
                        </button>
                    </div>
                </EditForm>
            }
        </div>
    </div>
</div>

@code {
    [Parameter] public int id { get; set; }
    private SalesPerson? vendedor;

    protected override async Task OnInitializedAsync()
    {
        vendedor = await SalesPersonService.GetSalesPersonByIdAsync(id);
    }

    private async Task ActualizarVendedor()
    {
        if (vendedor == null) return;
        var exito = await SalesPersonService.UpdateAsync(vendedor);
        if (exito) NavigationManager.NavigateTo("/sales-people");
    }

    private async Task Eliminar()
    {
        var exito = await SalesPersonService.DeleteAsync(id);
        if (exito) NavigationManager.NavigateTo("/sales-people");
    }

    private void Volver() => NavigationManager.NavigateTo("/sales-people");
}