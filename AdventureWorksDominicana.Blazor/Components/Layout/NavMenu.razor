@using Microsoft.AspNetCore.Components.Authorization

<div class="top-row navbar navbar-dark">
    <div class="container-fluid">
        <a class="navbar-brand" href="">AdventureWorks Dominicana</a>
    </div>
</div>

<input type="checkbox" title="Navigation menu" class="navbar-toggler" />

<div class="nav-scrollable" onclick="document.querySelector('.navbar-toggler').click()">
    <nav class="nav flex-column">
        
        @* ========== HOME MODULE ========== *@
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
                <span class="bi bi-house-door-fill-nav-menu" aria-hidden="true"></span> <small>Home</small>
            </NavLink>
        </div>

        <AuthorizeView Context="mainContext">
            <Authorized>
                @* ========== SALES MODULE (Visible para Customer y Admin) ========== *@
                <AuthorizeView Roles="Customer, Admin" Context="salesContext">
                    <Authorized>
                        <div class="accordion px-3 nav-item" id="accordionSales">
                            <div class="accordion-item bg-transparent border-0">
                                <div class="accordion-header">
                                    <button class="accordion-button collapsed bg-transparent px-3" type="button" data-bs-toggle="collapse" data-bs-target="#collapseSales">
                                        <span class="bi bi-cart-fill-nav-menu"></span> <small>Sales</small>
                                    </button>
                                </div>
                                <div id="collapseSales" class="accordion-collapse collapse" data-bs-parent="#accordionSales">
                                    <div class="accordion-body p-0 ps-3">
                                        <div class="nav-item pt-2"><NavLink class="nav-link" href="/Sales"><span class="bi bi-receipt-nav-menu"></span> <small>Sales</small></NavLink></div>
                                        <div class="nav-item"><NavLink class="nav-link" href="/SalesTerritory/Index"><span class="bi bi-map-fill-nav-menu"></span> <small>Sales Territories</small></NavLink></div>
                                        <div class="nav-item"><NavLink class="nav-link" href="/Currency/Index"><span class="bi bi-currency-dollar-nav-menu"></span> <small>Currencies</small></NavLink></div>
                                        <div class="nav-item"><NavLink class="nav-link" href="/ShoppingCartItem/Index"><span class="bi bi-cart-plus-nav-menu"></span> <small>Shopping Cart</small></NavLink></div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </Authorized>
                </AuthorizeView>

                @* ========== PURCHASING MODULE (Visible para Vendor y Admin) ========== *@
                <AuthorizeView Roles="Vendor, Admin" Context="purchasingContext">
                    <Authorized>
                        <div class="accordion px-3 nav-item" id="accordionPurchasing">
                            <div class="accordion-item bg-transparent border-0">
                                <div class="accordion-header">
                                    <button class="accordion-button collapsed bg-transparent px-3" type="button" data-bs-toggle="collapse" data-bs-target="#collapsePurchasing">
                                        <span class="bi bi-truck-nav-menu"></span> <small>Purchasing</small>
                                    </button>
                                </div>
                                <div id="collapsePurchasing" class="accordion-collapse collapse" data-bs-parent="#accordionPurchasing">
                                    <div class="accordion-body p-0 ps-3">
                                        <div class="nav-item pt-2"><NavLink class="nav-link" href="/Vendor/Index"><span class="bi bi-shop-nav-menu"></span> <small>Vendors</small></NavLink></div>
                                        <div class="nav-item"><NavLink class="nav-link" href="/ShipMethods"><span class="bi bi-send-plus-nav-menu"></span> <small>Ship Methods</small></NavLink></div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </Authorized>
                </AuthorizeView>

                @* ========== ADMIN ONLY MODULES (Products, Geography, HR, Config) ========== *@
                <AuthorizeView Roles="Admin" Context="adminContext">
                    <Authorized>
                        @* Products *@
                        <div class="accordion px-3 nav-item" id="accordionProducts">
                            <div class="accordion-item bg-transparent border-0">
                                <div class="accordion-header">
                                    <button class="accordion-button collapsed bg-transparent px-3" type="button" data-bs-toggle="collapse" data-bs-target="#collapseProducts">
                                        <span class="bi bi-bicycle-nav-menu"></span> <small>Products</small>
                                    </button>
                                </div>
                                <div id="collapseProducts" class="accordion-collapse collapse" data-bs-parent="#accordionProducts">
                                    <div class="accordion-body p-0 ps-3">
                                        <div class="nav-item pt-2"><NavLink class="nav-link" href="/Product/Index"><small>Products</small></NavLink></div>
                                        <div class="nav-item"><NavLink class="nav-link" href="/ProductCategory/Index"><small>Categories</small></NavLink></div>
                                        <div class="nav-item"><NavLink class="nav-link" href="/ProductDescription/Index"><small>Descriptions</small></NavLink></div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        @* Geography *@
                        <div class="accordion px-3 nav-item" id="accordionGeography">
                            <div class="accordion-item bg-transparent border-0">
                                <button class="accordion-button collapsed bg-transparent px-3" type="button" data-bs-toggle="collapse" data-bs-target="#collapseGeography">
                                    <span class="bi bi-globe-americas-nav-menu"></span> <small>Geography</small>
                                </button>
                                <div id="collapseGeography" class="accordion-collapse collapse" data-bs-parent="#accordionGeography">
                                    <div class="accordion-body p-0 ps-3">
                                        <div class="nav-item pt-2"><NavLink class="nav-link" href="/CountryRegions/Index"><small>Countries</small></NavLink></div>
                                        <div class="nav-item"><NavLink class="nav-link" href="/StateProvince/Index"><small>States</small></NavLink></div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        @* Human Resources *@
                        <div class="accordion px-3 nav-item" id="accordionHR">
                            <div class="accordion-item bg-transparent border-0">
                                <button class="accordion-button collapsed bg-transparent px-3" type="button" data-bs-toggle="collapse" data-bs-target="#collapseHR">
                                    <span class="bi bi-people-fill-nav-menu"></span> <small>Human Resources</small>
                                </button>
                                <div id="collapseHR" class="accordion-collapse collapse" data-bs-parent="#accordionHR">
                                    <div class="accordion-body p-0 ps-3">
                                        <div class="nav-item pt-2"><NavLink class="nav-link" href="/Employee/Index"><small>Employees</small></NavLink></div>
                                        <div class="nav-item"><NavLink class="nav-link" href="/Person/Index"><small>Person</small></NavLink></div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        @* Configuration *@
                        <div class="accordion px-3 nav-item" id="accordionConfig">
                            <div class="accordion-item bg-transparent border-0">
                                <button class="accordion-button collapsed bg-transparent px-3" type="button" data-bs-toggle="collapse" data-bs-target="#collapseConfig">
                                    <span class="bi bi-gear-fill-nav-menu"></span> <small>Configuration</small>
                                </button>
                                <div id="collapseConfig" class="accordion-collapse collapse" data-bs-parent="#accordionConfig">
                                    <div class="accordion-body p-0 ps-3">
                                        <div class="nav-item pt-2"><NavLink class="nav-link" href="/PhoneNumberType/Index"><small>Phone Types</small></NavLink></div>
                                        <div class="nav-item"><NavLink class="nav-link" href="/ContactType/Index"><small>Contact Types</small></NavLink></div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </Authorized>
                </AuthorizeView>

                @* ========== LOGOUT SECTION ========== *@
                <div class="nav-item px-3 mt-3">
                    <form action="Account/Logout" method="post">
                        <AntiforgeryToken />
                        <input type="hidden" name="ReturnUrl" value="" />
                        <button type="submit" class="nav-link btn btn-link w-100 text-start p-0 m-0 border-0 shadow-none">
                            <span class="bi bi-door-closed-fill-nav-menu" aria-hidden="true"></span>
                            <small>Logout (@mainContext.User.Identity?.Name)</small>
                        </button>
                    </form>
                </div>
            </Authorized>

            <NotAuthorized>
                @* ========== AUTH MODULE (Login/Register) ========== *@
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="/Account/Register">
                        <span class="bi bi-person-plus-fill-nav-menu" aria-hidden="true"></span> <small>Register</small>
                    </NavLink>
                </div>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="/Account/Login">
                        <span class="bi bi-box-arrow-in-right-nav-menu" aria-hidden="true"></span> <small>Login</small>
                    </NavLink>
                </div>
            </NotAuthorized>
        </AuthorizeView>

    </nav>
</div>