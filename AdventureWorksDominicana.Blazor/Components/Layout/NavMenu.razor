@using Microsoft.AspNetCore.Components.Authorization

<div class="top-row navbar navbar-dark">
    <div class="container-fluid">
        <a class="d-flex align-items-center" href="/Home/Page">
            <img src="logo-long.svg" class="img-fluid" />
        </a>
    </div>
</div>

<input type="checkbox" title="Navigation menu" class="navbar-toggler" />

<div class="nav-scrollable" onclick="document.querySelector('.navbar-toggler').click()">
    <nav class="nav flex-column">
        
        @* ========== HOME (Todos) ========== *@
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
                <span class="bi bi-house-door-fill-nav-menu"></span> <small>Home</small>
            </NavLink>
        </div>

       
        <AuthorizeView Context="authContext">
            <Authorized>
                
                @* ========== SALES (Customer y Admin) ========== *@
                <AuthorizeView Roles="Customer, Admin" Context="salesContext">
                    <Authorized>
                        <div class="accordion px-3 nav-item" id="accordionSales">
                            <div class="accordion-item bg-transparent border-0">
                                <div class="accordion-header">
                                    <button class="accordion-button collapsed bg-transparent px-3" type="button" data-bs-toggle="collapse" data-bs-target="#collapseSales">
                                        <span class="bi bi-cart-fill-nav-menu"></span> <small>Sales</small>
                                    </button>
                                </div>
                                <div id="collapseSales" class="accordion-collapse collapse" data-bs-parent="#accordionSales">
                                    <div class="accordion-body p-0 ps-3">
                                        <div class="nav-item pt-2"><NavLink class="nav-link" href="/Sales"><small>Sales</small></NavLink></div>
                                        
                                        @* Solo el Admin ve Territories y Currencies *@
                                        <AuthorizeView Roles="Admin" Context="adminSalesContext">
                                            <Authorized>
                                                <div class="nav-item"><NavLink class="nav-link" href="/SalesTerritory/Index"><small>Sales Territories</small></NavLink></div>
                                                <div class="nav-item"><NavLink class="nav-link" href="/Currency/Index"><small>Currencies</small></NavLink></div>
                                            </Authorized>
                                        </AuthorizeView>

                                        <div class="nav-item"><NavLink class="nav-link" href="/ShoppingCartItem/Index"><small>Shopping Cart</small></NavLink></div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </Authorized>
                </AuthorizeView>

                @* ========== PRODUCTS (Vendor y Admin) ========== *@
                <AuthorizeView Roles="Vendor, Admin" Context="productContext">
                    <Authorized>
                        <div class="accordion px-3 nav-item" id="accordionProducts">
                            <div class="accordion-item bg-transparent border-0">
                                <button class="accordion-button collapsed bg-transparent px-3" type="button" data-bs-toggle="collapse" data-bs-target="#collapseProducts">
                                    <span class="bi bi-bicycle-nav-menu"></span> <small>Products</small>
                                </button>
                                <div id="collapseProducts" class="accordion-collapse collapse" data-bs-parent="#accordionProducts">
                                    <div class="accordion-body p-0 ps-3">
                                        <div class="nav-item pt-2"><NavLink class="nav-link" href="/Product/Index"><small>Products</small></NavLink></div>
                                        <div class="nav-item"><NavLink class="nav-link" href="/ProductCategory/Index"><small>Categories</small></NavLink></div>
                                        
                                        <AuthorizeView Roles="Admin" Context="adminProdContext">
                                            <Authorized>
                                                <div class="nav-item"><NavLink class="nav-link" href="/ProductDescription/Index"><small>Descriptions</small></NavLink></div>
                                                <div class="nav-item"><NavLink class="nav-link" href="/Culture/Index"><small>Cultures</small></NavLink></div>
                                                <div class="nav-item"><NavLink class="nav-link" href="/Location/Index"><small>Locations</small></NavLink></div>
                                            </Authorized>
                                        </AuthorizeView>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </Authorized>
                </AuthorizeView>

                @* ========== GEOGRAPHY (Solo Admin) ========== *@
                <AuthorizeView Roles="Admin" Context="geoContext">
                    <Authorized>
                        <div class="accordion px-3 nav-item" id="accordionGeography">
                            <div class="accordion-item bg-transparent border-0">
                                <button class="accordion-button collapsed bg-transparent px-3" type="button" data-bs-toggle="collapse" data-bs-target="#collapseGeography">
                                    <span class="bi bi-globe-americas-nav-menu"></span> <small>Geography</small>
                                </button>
                                <div id="collapseGeography" class="accordion-collapse collapse" data-bs-parent="#accordionGeography">
                                    <div class="accordion-body p-0 ps-3">
                                        <div class="nav-item pt-2"><NavLink class="nav-link" href="/CountryRegions/Index"><small>Countries/Regions</small></NavLink></div>
                                        <div class="nav-item"><NavLink class="nav-link" href="/StateProvince/Index"><small>States/Provinces</small></NavLink></div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </Authorized>
                </AuthorizeView>

                @* ========== HUMAN RESOURCES (Solo Admin) ========== *@
                <AuthorizeView Roles="Admin" Context="hrContext">
                    <Authorized>
                        <div class="accordion px-3 nav-item" id="accordionHR">
                            <div class="accordion-item bg-transparent border-0">
                                <button class="accordion-button collapsed bg-transparent px-3" type="button" data-bs-toggle="collapse" data-bs-target="#collapseHR">
                                    <span class="bi bi-people-fill-nav-menu"></span> <small>Human Resources</small>
                                </button>
                                <div id="collapseHR" class="accordion-collapse collapse" data-bs-parent="#accordionHR">
                                    <div class="accordion-body p-0 ps-3">
                                        <div class="nav-item pt-2"><NavLink class="nav-link" href="/Employee/Index"><small>Employees</small></NavLink></div>
                                        <div class="nav-item"><NavLink class="nav-link" href="/Department/Index"><small>Departments</small></NavLink></div>
                                        <div class="nav-item"><NavLink class="nav-link" href="/Person/Index"><small>Person</small></NavLink></div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </Authorized>
                </AuthorizeView>

                @* ========== PURCHASING (Vendor y Admin) ========== *@
                <AuthorizeView Roles="Vendor, Admin" Context="purchContext">
                    <Authorized>
                        <div class="accordion px-3 nav-item" id="accordionPurchasing">
                            <div class="accordion-item bg-transparent border-0">
                                <button class="accordion-button collapsed bg-transparent px-3" type="button" data-bs-toggle="collapse" data-bs-target="#collapsePurchasing">
                                    <span class="bi bi-truck-nav-menu"></span> <small>Purchasing</small>
                                </button>
                                <div id="collapsePurchasing" class="accordion-collapse collapse" data-bs-parent="#accordionPurchasing">
                                    <div class="accordion-body p-0 ps-3">
                                        <AuthorizeView Roles="Admin" Context="adminPurchContext">
                                            <Authorized>
                                                <div class="nav-item pt-2"><NavLink class="nav-link" href="/Vendor/Index"><small>Vendors</small></NavLink></div>
                                            </Authorized>
                                        </AuthorizeView>
                                        <div class="nav-item"><NavLink class="nav-link" href="/ShipMethods"><small>Ship Methods</small></NavLink></div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </Authorized>
                </AuthorizeView>

                @* ========== CONFIGURATION (Solo Admin) ========== *@
                <AuthorizeView Roles="Admin" Context="configContext">
                    <Authorized>
                        <div class="accordion px-3 nav-item" id="accordionConfig">
                            <div class="accordion-item bg-transparent border-0">
                                <button class="accordion-button collapsed bg-transparent px-3" type="button" data-bs-toggle="collapse" data-bs-target="#collapseConfig">
                                    <span class="bi bi-gear-fill-nav-menu"></span> <small>Configuration</small>
                                </button>
                                <div id="collapseConfig" class="accordion-collapse collapse" data-bs-parent="#accordionConfig">
                                    <div class="accordion-body p-0 ps-3">
                                        <div class="nav-item pt-2"><NavLink class="nav-link" href="/PhoneNumberType/Index"><small>Phone Number Types</small></NavLink></div>
                                        <div class="nav-item"><NavLink class="nav-link" href="/ContactType/Index"><small>Contact Types</small></NavLink></div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </Authorized>
                </AuthorizeView>

            </Authorized>

            <NotAuthorized>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="/Account/Register"><small>Register</small></NavLink>
                </div>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="/Account/Login"><small>Login</small></NavLink>
                </div>
            </NotAuthorized>
        </AuthorizeView>
    </nav>
</div>

       


    </nav>
</div>